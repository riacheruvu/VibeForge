OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_TOKEN=change-me
OPENCLAW_DISABLE_BONJOUR=1
OPENCLAW_TZ=America/Denver
OPENCLAW_SANDBOX_IMAGE=vibecheckbench-openclaw-sandbox:local
OPENCLAW_SANDBOX_MODE=all
OPENCLAW_SANDBOX_SCOPE=session
OPENCLAW_SANDBOX_WORKSPACE_ACCESS=none
OPENCLAW_SANDBOX_NETWORK=bridge

# -- Provider selection ------------------------------------------------------
# Options:
#   llamacpp   -> llama.cpp server HTTP API (recommended, inference runs outside sandbox)
#   openai     -> OpenAI API (requires OPENAI_API_KEY)
#   anthropic  -> Anthropic API (requires ANTHROPIC_API_KEY)
VIBECHECKBENCH_PROVIDER=llamacpp
VIBECHECKBENCH_MODEL=

# Optional: use a separate judge to reduce generator/responder/judge circularity.
# Leave blank to reuse VIBECHECKBENCH_PROVIDER and VIBECHECKBENCH_MODEL.
VIBECHECKBENCH_JUDGE_PROVIDER=
VIBECHECKBENCH_JUDGE_MODEL=

# -- llama.cpp server --------------------------------------------------------
# Two ways to run the server:
#
# Option A - server on your Windows host (default):
#   llama-server.exe -m C:\models\phi-3-mini.gguf --port 8080
#   Leave VIBECHECKBENCH_LLAMACPP_URL as the default below.
#
# Option B - server in Docker (docker compose --profile llama up -d):
#   Set VIBECHECKBENCH_LLAMACPP_URL=http://llama-server:8080
#   Set VIBECHECKBENCH_MODELS_DIR and VIBECHECKBENCH_MODEL_FILE below.
#
VIBECHECKBENCH_LLAMACPP_URL=http://host.docker.internal:8080
# Optional bearer token for remote OpenAI-compatible endpoints (Together, Fireworks, Groq, vLLM, etc.)
VIBECHECKBENCH_LLAMACPP_API_KEY=

# For Option B (llama-server Docker profile):
VIBECHECKBENCH_MODELS_DIR=./models
VIBECHECKBENCH_MODEL_FILE=model.gguf

# llama-server tuning
VIBECHECKBENCH_CTX_SIZE=2048
VIBECHECKBENCH_N_THREADS=4
VIBECHECKBENCH_N_GPU_LAYERS=0    # set >0 if you have a GPU

# -- Hosted providers --------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# -- Benchmark tuning --------------------------------------------------------
VIBECHECKBENCH_NUM_CASES=10
VIBECHECKBENCH_REPEAT=1
VIBECHECKBENCH_LOCAL_FAST=1    # set to 0 for longer, higher-quality outputs

# llama-server port when using the Docker profile
LLAMACPP_PORT=8080
