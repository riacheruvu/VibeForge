{
  "name": "vibeforge",
  "private": true,
  "type": "module",
  "description": "VibeForge — measure and improve personal AI setup fit",
  "repository": {
    "type": "git",
    "url": "https://github.com/riacheruvu/VibeForge.git"
  },
  "homepage": "https://github.com/riacheruvu/VibeForge",
  "bin": {
    "vibeforge": "bin/vibeforge.mjs"
  },
  "scripts": {
    "vibeforge": "node bin/vibeforge.mjs",
    "start": "node bin/vibeforge.mjs --help",
    "dashboard": "node skills/vibeforge/dashboard/server.mjs",
    "dashboard:demo": "node skills/vibeforge/scripts/build-dashboard-demo.mjs",
    "chart:demo": "node skills/vibeforge/scripts/chart-results.mjs --input examples/promptfoo-results.user-fit-demo.json --out reports/skill-chart.html",
    "skill:install": "node skills/vibeforge/scripts/install-codex-skill.mjs",
    "promptfoo:check": "node skills/vibeforge/scripts/check-promptfoo.mjs",
    "fit:mine": "node skills/vibeforge/scripts/mine-conversation-history.mjs",
    "fit:promote": "node skills/vibeforge/scripts/promote-history-candidates.mjs",
    "fit:draft": "node skills/vibeforge/scripts/draft-test-case.mjs",
    "fit:review": "node skills/vibeforge/scripts/create-fit-review.mjs",
    "fit:recommend": "node skills/vibeforge/scripts/recommend-next-experiment.mjs",
    "fit:plan": "node skills/vibeforge/scripts/plan-setup-experiment.mjs",
    "fit:optimize": "node skills/vibeforge/scripts/optimize-config.mjs",
    "fit:eval": "node skills/vibeforge/scripts/run-fit-eval.mjs",
    "case:studies": "node skills/vibeforge/scripts/run-case-study.mjs --all"
  }
}
